# PartFlow environment — copy to .env and adjust. NEVER commit .env.
# All data is synthetic; these are local-stack credentials only.

# ── Postgres (single source of truth: the analytics warehouse) ──────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port for reaching Postgres from the host (dbt/generator run locally).
# Defaults to 5433 to avoid clashing with a local Postgres on 5432.
POSTGRES_HOST_PORT=5433
POSTGRES_USER=partflow
POSTGRES_PASSWORD=partflow
# Warehouse database that dbt builds into and BI/web read from.
POSTGRES_DB=partflow

# Read-only role the web app connects with (created in Phase 7).
POSTGRES_READONLY_USER=partflow_ro
POSTGRES_READONLY_PASSWORD=partflow_ro

# Full warehouse URL (used by dbt, the generator, and ingestion).
DATABASE_URL=postgresql://partflow:partflow@postgres:5432/partflow

# ── Airflow (metadata DB lives in the same Postgres instance) ───────────────
# Host UID Airflow runs as so bind-mounted files are readable (Linux/WSL: `id -u`).
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── Grafana ─────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Metabase (app DB lives in the same Postgres instance) ───────────────────
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=metabase
MB_DB_PASS=metabase
MB_DB_HOST=postgres
